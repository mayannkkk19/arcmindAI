generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  free
  pro
  enterprise
}


model User {
  id                  String                @id @default(auto()) @map("_id") @db.ObjectId
  username            String
  email               String                @unique
  password            String                // hashed password
  avatar              String?               // optional profile picture
  isVerified          Boolean               @default(false)
  otp                 String?               // optional OTP code
  otpExpiry           DateTime?             // optional OTP expiry
  role                Role                  @default(USER)
  plan                Plan                  @default(free) // free, pro, enterprise
  subscriptionId      String?               // Dodo subscription ID
  subscriptionStatus  String?               // active, canceled, expired, null
  currentPeriodEnd    DateTime?             // end of current billing period
  githubAccessToken   String?               // GitHub OAuth access token
  geminiApiKey        String?               // Encrypted Gemini API key
  openaiApiKey        String?               // Encrypted OpenAI API key
  encryptionKey       String?               // User-specific encryption key for API keys
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  generations         Generation[]
  resetPasswordTokens ResetPasswordToken[]
  webhooks            Webhook[]

  @@map("users")
}

model Webhook {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  url         String
  secret      String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String            @db.ObjectId
  user        User              @relation(fields: [userId], references: [id])
  deliveries  WebhookDelivery[]

  @@index([userId])

  // Prevent duplicate webhook URLs per user
  @@unique([userId, url])

  @@map("webhooks")
}

model WebhookDelivery {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  webhookId      String   @db.ObjectId
  webhook        Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  attempts       Int      @default(0)
  success        Boolean
  responseStatus Int?
  responseBody   String?
  retryCount     Int      @default(0)
  createdAt      DateTime @default(now())
  @@index([webhookId])
  @@map("webhook_deliveries")
}

model Generation {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userInput        String
  generatedOutput  Json?     // stores structured system design JSON
  frontendData     Json?
  githubGeneration String?  // stores Mermaid diagram for GitHub repos
  tasksData        Json?     // stores AI-generated task breakdown
  doubtChatCount   Int      @default(0) // tracks number of doubt questions for free tier limit
  isPublic         Boolean @default(false)
  shareId          String?  @unique
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id])
  rating           Int?     

  @@index([userId])
}

model ResetPasswordToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash String   // hashed reset token
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime // token expiry time

  @@index([tokenHash])
  @@index([userId])
  @@map("reset_password_tokens")
}
